{
  "id": null,
  "uid": "finguard-main",
  "title": "finGuard — Fraud Detection",
  "tags": ["finguard", "fraud", "ml"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Fraud Requests Total",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "fraud_requests_total",
          "legendFormat": "total requests"
        }
      ]
    },
    {
      "id": 2,
      "title": "LLM Requests Total",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "llm_requests_total",
          "legendFormat": "llm requests"
        }
      ]
    },
    {
      "id": 3,
      "title": "Fraud Request Rate (req/min)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(fraud_requests_total[1m]) * 60",
          "legendFormat": "req/min"
        }
      ]
    },
    {
      "id": 4,
      "title": "P99 Fraud Inference Latency (ms)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(fraud_request_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p99 ms"
        }
      ]
    },
    {
      "id": 5,
      "title": "Fraud Inference Latency Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(fraud_request_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p50 ms"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(fraud_request_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95 ms"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(fraud_request_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p99 ms"
        }
      ]
    },
    {
      "id": 6,
      "title": "LLM Latency Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(llm_request_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p50 ms"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(llm_request_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p99 ms"
        }
      ]
    }
  ]
}
